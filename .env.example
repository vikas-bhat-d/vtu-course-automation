# VTU Lecture Automation Configuration
# Copy this file to .env and fill in your actual credentials

# VTU Account Credentials
VTU_EMAIL=your-email@gmail.com
VTU_PASSWORD=your-password

# Course Configuration
VTU_COURSE_SLUG=1-social-networks

# API Configuration - no need to modify unless changed
VTU_API_BASE_URL=https://online.vtu.ac.in/api/v1

# Parallel Processing
VTU_BATCH_SIZE=10
VTU_MAX_ATTEMPTS=100

# ── Web Server ─────────────────────────────────────────────────────────────
PORT=3000

# Allowed CORS origin for your Vercel frontend (use * to allow all during dev)
CORS_ORIGIN=*

# Your GitHub repo URL shown in the UI
GITHUB_URL=https://github.com/vikas-bhat-d/vtu-course-automation

# ── Upstash KV (student & lecture counters) ────────────────────────────────
# Get these from https://console.upstash.com → your Redis database → REST API
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-rest-api-token
