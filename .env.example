# VTU Lecture Automation Configuration
# Copy this file to .env and fill in your actual credentials

# VTU Account Credentials
VTU_EMAIL=your-email@gmail.com
VTU_PASSWORD=your-password

# Course Configuration
VTU_COURSE_SLUG=1-social-networks

# API Configuration - no need to modify unless changed
VTU_API_BASE_URL=https://online.vtu.ac.in/api/v1

# Parallel Processing
VTU_BATCH_SIZE=10
VTU_MAX_ATTEMPTS=100

# ── Web Server ─────────────────────────────────────────────────────────────
PORT=3000

# Allowed CORS origin for your Vercel frontend (use * to allow all during dev)
CORS_ORIGIN=*

# Your GitHub repo URL shown in the UI
GITHUB_URL=https://github.com/vikas-bhat-d/vtu-course-automation

# ── Upstash KV (optional: for statistics dashboard) ────────────────────────
# Leave empty to use in-memory stats (no Redis needed for local use)
# Setup Guide:
#   1. Go to https://console.upstash.com → Create Database (free tier available)
#   2. Click your database → "REST API" tab
#   3. Copy the UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN below
#   4. Paste them here (or leave empty if you don't need stats tracking)
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-rest-api-token

# ── Server Runtime Configuration (optional) ─────────────────────────────────
# These settings control automation behavior and can be changed at runtime
# via admin endpoints if ADMIN_PASSWORD is set

# Parallel processing settings (optional)
DEFAULT_BATCH_SIZE=10           # Lectures processed in parallel per batch (1-50)
DEFAULT_MAX_ATTEMPTS=50         # Max rounds of retries per batch (1-500)

# Delay and retry settings (in milliseconds)
RETRY_DELAY_MS=2000            # Wait before retrying after VTU throttling (0-30000)
REQUEST_DELAY_MS=500           # Delay between individual requests to avoid rate limits (0-10000)
MAX_RETRIES=10                 # Max retries for network/server errors (1-30)

# Job queue control
MAX_CONCURRENT=2               # Max concurrent jobs for hosted deployments (1-10)

# ── Admin Access (optional) ─────────────────────────────────────────────────
# Set this to enable runtime configuration endpoints:
#   GET /api/admin/config?password=<pw>
#   GET /api/admin/monitor?password=<pw>
#   GET /api/admin/notification?password=<pw>
# ADMIN_PASSWORD=your-secret-admin-password

# ── Environment ─────────────────────────────────────────────────────────────
# NODE_ENV=development          # Set to "production" to enable stricter rate limiting
